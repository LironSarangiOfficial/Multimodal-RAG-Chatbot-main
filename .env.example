# ---- Copy this file to ".env" and fill in your key ----

# Your Gemini API key (from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_gemini_api_key_here

# LLM model (gemini-2.5-flash is a good cheap default)
GEMINI_MODEL=gemini-2.5-flash

# HuggingFace models (defaults are fine for most people)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ChromaDB
CHROMA_COLLECTION_NAME=internal_pdf_rag
# CHROMA_DB_PATH=./chroma_db

# Retrieval tuning
INITIAL_RETRIEVAL_K=15
RERANKED_TOP_K=5
CHUNK_CHAR_LIMIT=1200

# Local model folders (defaults keep everything inside the project)
# HF_HOME=./models/hf
# DOCLING_ARTIFACTS_PATH=./models/docling

# Set to 1 on the OFFLINE office laptop AFTER models are downloaded.
OFFLINE=0
